source "https://rubygems.org"

# Matches the exact Jekyll version GitHub Pages runs.
# Keeps your local build identical to production.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Windows/JRuby compatibility — safe to leave in on Mac/Linux
gem "tzinfo", ">= 1", "< 3"
gem "tzinfo-data"
gem "wdm", "~> 0.1"
